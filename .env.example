# Copy to .env and fill in real values. .env is gitignored — never commit real secrets.

# ---- Environment ----
OPENLAKE_ENV=local            # local | dev | prod

# ---- Postgres: operational sources (Sales, Inventory) ----
SOURCE_DB_HOST=localhost
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=openlake_source
SOURCE_DB_USER=openlake
SOURCE_DB_PASSWORD=changeme

# ---- Postgres: warehouse + metadata ----
WAREHOUSE_DB_HOST=localhost
WAREHOUSE_DB_PORT=5433
WAREHOUSE_DB_NAME=openlake_warehouse
WAREHOUSE_DB_USER=openlake
WAREHOUSE_DB_PASSWORD=changeme

# ---- MinIO (S3-compatible object storage) ----
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=openlake
MINIO_SECRET_KEY=changeme123
MINIO_SECURE=false
MINIO_BUCKET_LANDING=openlake-landing
MINIO_BUCKET_BRONZE=openlake-bronze
MINIO_BUCKET_SILVER=openlake-silver
MINIO_BUCKET_GOLD=openlake-gold

# ---- Customer API (simulated source) ----
# host-side value for running ingestion outside Docker; inside Docker Compose
# this is overridden to http://customer-api:8080 (see docker-compose.yml)
CUSTOMER_API_BASE_URL=http://localhost:8000
CUSTOMER_API_KEY=changeme

# ---- Airflow ----
AIRFLOW_UID=50000
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# ---- Logging ----
LOG_LEVEL=INFO
